---
// Ubuntu Budgie Welcome — About
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome — About</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --accent-light:  #dbeafe;
      --hover-bg:      #ebebeb;
      --card-border:   #e8e8e8;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-lg:     14px;
      --radius-win:    14px;
      --font:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); font-family: var(--font);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 860px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 680px; min-height: 480px;
      background: var(--win-bg); border-radius: var(--radius-win);
      box-shadow: var(--shadow-win); overflow: hidden;
      display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 8px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .back-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--accent); font-family: var(--font);
      font-size: 13px; font-weight: 500;
      padding: 4px 6px 4px 2px; border-radius: var(--radius-sm);
      transition: background .12s; text-decoration: none;
    }
    .back-btn:hover { background: var(--accent-light); }
    .back-btn svg { width: 16px; height: 16px; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-size: 13px; font-weight: 500;
      color: var(--text-secondary); letter-spacing: -.01em; pointer-events: none;
    }

    /* ── Layout: hero left, scroll right ── */
    .main { flex: 1; display: flex; overflow: hidden; min-height: 0; }

    /* ── Hero panel ── */
    .hero-panel {
      width: 200px; flex-shrink: 0;
      background: linear-gradient(160deg, #eff6ff 0%, #f5f3ff 100%);
      border-right: 1px solid var(--card-border);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 28px 18px; gap: 14px;
      position: relative; overflow: hidden;
    }
    .hero-panel::before {
      content: ''; position: absolute;
      top: -50px; right: -50px;
      width: 160px; height: 160px; border-radius: 50%;
      background: rgba(37,99,235,.06); pointer-events: none;
    }
    .hero-panel::after {
      content: ''; position: absolute;
      bottom: -40px; left: -40px;
      width: 130px; height: 130px; border-radius: 50%;
      background: rgba(124,58,237,.05); pointer-events: none;
    }
    .hero-icon {
      width: 80px; height: 80px; border-radius: 20px;
      background: #fff;
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow-md), 0 0 0 1px rgba(0,0,0,.05);
      position: relative; z-index: 1;
    }
    .hero-icon img { width: 58px; height: 58px; object-fit: contain; }
    .hero-tagline {
      font-size: 13px; font-weight: 600; color: var(--text-primary);
      text-align: center; line-height: 1.4;
      position: relative; z-index: 1;
    }
    .hero-sub {
      font-size: 11.5px; color: var(--text-secondary);
      text-align: center; line-height: 1.55;
      position: relative; z-index: 1;
    }

    /* OS comparison row */
    .os-row {
      display: flex; flex-direction: column; align-items: center;
      gap: 10px; position: relative; z-index: 1; margin-top: 6px;
    }
    .os-row-label {
      font-size: 10px; font-weight: 600; letter-spacing: .06em;
      text-transform: uppercase; color: var(--text-tertiary);
    }
    .os-icons { display: flex; gap: 8px; align-items: center; }
    .os-icon {
      width: 28px; height: 28px; border-radius: 7px;
      background: #fff; border: 1px solid var(--card-border);
      display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow-sm);
    }
    .os-icon img { width: 18px; height: 18px; object-fit: contain; }
    .os-plus {
      font-size: 11px; color: var(--text-tertiary); font-weight: 500;
    }

    /* ── Scroll content ── */
    .content-scroll {
      flex: 1; overflow-y: auto; min-height: 0;
      padding: 24px 28px 28px;
    }
    .content-scroll::-webkit-scrollbar { width: 6px; }
    .content-scroll::-webkit-scrollbar-track { background: transparent; }
    .content-scroll::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .content-scroll::-webkit-scrollbar-thumb:hover { background: #aaa; }

    /* ── Section heading ── */
    .page-title {
      font-size: 20px; font-weight: 600;
      color: var(--text-primary); letter-spacing: -.02em; margin-bottom: 4px;
    }
    .page-subtitle {
      font-size: 13px; color: var(--text-secondary); line-height: 1.55;
      margin-bottom: 20px;
    }

    /* ── Cat divider ── */
    .cat-divider {
      display: flex; align-items: center; gap: 10px; margin: 22px 0 14px;
    }
    .cat-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: .07em;
      text-transform: uppercase; color: var(--text-tertiary); white-space: nowrap;
    }
    .cat-line { flex: 1; height: 1px; background: var(--card-border); }

    /* ── Body text ── */
    .body-text { font-size: 13px; color: var(--text-secondary); line-height: 1.65; }
    .body-text p + p { margin-top: 9px; }
    .body-text a { color: var(--accent); text-decoration: none; }
    .body-text a:hover { text-decoration: underline; }

    /* ── Linux stat row ── */
    .stat-row {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
      margin: 16px 0;
    }
    .stat-card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-md); padding: 13px 14px;
      animation: fadeUp .28s ease both;
    }
    .stat-card:nth-child(1) { animation-delay: .04s; }
    .stat-card:nth-child(2) { animation-delay: .08s; }
    .stat-card:nth-child(3) { animation-delay: .12s; }
    .stat-icon { font-size: 18px; margin-bottom: 5px; }
    .stat-label { font-size: 12px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
    .stat-desc  { font-size: 11.5px; color: var(--text-secondary); line-height: 1.4; }

    /* ── Objectives list ── */
    .objective-list { display: flex; flex-direction: column; gap: 7px; }
    .objective-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 10px 13px; border-radius: var(--radius-md);
      background: #fafafa; border: 1px solid var(--card-border);
      font-size: 12.5px; color: var(--text-secondary); line-height: 1.55;
      animation: fadeUp .26s ease both;
    }
    .objective-item:nth-child(1) { animation-delay: .04s; }
    .objective-item:nth-child(2) { animation-delay: .07s; }
    .objective-item:nth-child(3) { animation-delay: .10s; }
    .objective-item:nth-child(4) { animation-delay: .13s; }
    .objective-item:nth-child(5) { animation-delay: .16s; }
    .obj-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0; margin-top: 5px;
    }

    /* ── Budgie feature pills ── */
    .feature-pills { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 10px; }
    .feature-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 12px; border-radius: 20px;
      background: var(--accent-light); color: var(--accent);
      border: 1px solid rgba(37,99,235,.18);
      font-size: 12px; font-weight: 500;
    }
    .feature-pill svg { width: 13px; height: 13px; }

    /* ── App grid ── */
    .app-grid {
      display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;
      margin: 14px 0;
    }
    .app-card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-md); padding: 12px 8px 10px;
      display: flex; flex-direction: column; align-items: center; gap: 7px;
      transition: box-shadow .14s, transform .12s;
      animation: fadeUp .26s ease both;
    }
    .app-card:hover { box-shadow: var(--shadow-sm); transform: translateY(-1px); }
    .app-card:nth-child(1) { animation-delay: .04s; }
    .app-card:nth-child(2) { animation-delay: .07s; }
    .app-card:nth-child(3) { animation-delay: .10s; }
    .app-card:nth-child(4) { animation-delay: .13s; }
    .app-card:nth-child(5) { animation-delay: .16s; }
    .app-card img { width: 38px; height: 38px; object-fit: contain; }
    .app-name { font-size: 12px; font-weight: 500; color: var(--text-primary); text-align: center; }
    .app-role { font-size: 10.5px; color: var(--text-tertiary); text-align: center; }

    /* ── Open Source section ── */
    .oss-card {
      display: flex; align-items: flex-start; gap: 18px;
      padding: 16px 18px; border-radius: var(--radius-lg);
      border: 1px solid var(--card-border); background: #fafafa;
      margin-top: 4px;
    }
    .oss-logo {
      width: 64px; height: 64px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      background: #fff; border: 1px solid var(--card-border);
      border-radius: var(--radius-md); overflow: hidden;
    }
    .oss-logo img { width: 50px; height: 50px; object-fit: contain; }
    .oss-body { flex: 1; min-width: 0; }
    .oss-title { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 7px; }
    .oss-text { font-size: 12.5px; color: var(--text-secondary); line-height: 1.65; }
    .oss-text p + p { margin-top: 8px; }
    .oss-text a { color: var(--accent); text-decoration: none; }
    .oss-text a:hover { text-decoration: underline; }

    /* ── Contributor chips ── */
    .contributor-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
    .contributor-chip {
      padding: 3px 10px; border-radius: 20px;
      background: #f0f0f0; color: var(--text-secondary);
      border: 1px solid var(--card-border);
      font-size: 11.5px; font-weight: 500;
    }

    /* ── Win Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 24px; border-top: 1px solid var(--card-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-secondary);
    }
    .discourse-link img { height: 18px; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: var(--hover-bg); color: var(--text-primary); }
    .social-link svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<div class="window">

  <!-- Title Bar -->
  <div class="titlebar">
    <a href="index" class="back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
      </svg>
      Back
    </a>
    <span class="titlebar-label">About Ubuntu Budgie</span>
  </div>

  <div class="main">

    <!-- ── Hero Panel ── -->
    <div class="hero-panel">
      <div class="hero-icon">
        <img src="img/distro-icon.svg" alt="Ubuntu Budgie" />
      </div>
      <div class="hero-tagline">Ubuntu Budgie</div>
      <div class="hero-sub">Simplicity &amp; Elegance</div>

      <div class="os-row">
        <div class="os-row-label">Similar to</div>
        <div class="os-icons">
          <div class="os-icon"><img src="img/os/windows.svg" alt="Windows" /></div>
          <span class="os-plus">·</span>
          <div class="os-icon"><img src="img/os/apple.svg" alt="macOS" /></div>
          <span class="os-plus">·</span>
          <div class="os-icon"><img src="img/os/chrome.svg" alt="Chrome OS" /></div>
        </div>
      </div>
    </div>

    <!-- ── Scrollable Content ── -->
    <div class="content-scroll">

      <div class="page-title">What is Ubuntu Budgie?</div>
      <p class="page-subtitle">An operating system built on the trusted Ubuntu base, paired with the elegant Budgie desktop — free, open-source, and designed for everyone.</p>

      <!-- Linux everywhere -->
      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-icon">⚡</div>
          <div class="stat-label">Supercomputers</div>
          <div class="stat-desc">Linux powers most of the world's fastest and most powerful supercomputers.</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🌐</div>
          <div class="stat-label">The Internet</div>
          <div class="stat-desc">The majority of servers that make up the internet's backbone run Linux.</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">🏢</div>
          <div class="stat-label">Enterprise</div>
          <div class="stat-desc">Corporations worldwide rely on Linux for stability, security, and reliability.</div>
        </div>
      </div>

      <div class="body-text">
        <p>Ubuntu Budgie is a stable, easy-to-use operating system with a configurable desktop environment, ideal for those who want the most from their computer and prefer a traditional desktop metaphor. With modest hardware requirements, it suits both modern and older machines alike.</p>
        <p>The operating system is more secure and better supported than those pre-installed on most home computers today. You get a complete, full-featured OS pre-configured with everything you need — and the freedom to change anything about how it looks, works, or what it runs.</p>
      </div>

      <!-- Objectives -->
      <div class="cat-divider">
        <span class="cat-label">Objectives</span>
        <div class="cat-line"></div>
      </div>

      <div class="objective-list">
        <div class="objective-item"><div class="obj-dot"></div>Accessible to all, regardless of language and physical ability.</div>
        <div class="objective-item"><div class="obj-dot"></div>Increase both Ubuntu and Budgie desktop user adoption worldwide.</div>
        <div class="objective-item"><div class="obj-dot"></div>Provide a Ubuntu-based distro for users who prefer a traditional desktop metaphor.</div>
        <div class="objective-item"><div class="obj-dot"></div>Contribute upstream to projects like BuddiesOfBudgie and Debian so all Linux communities benefit.</div>
        <div class="objective-item"><div class="obj-dot"></div>Software selection will favour functionality and stability over lightness and whimsy.</div>
      </div>

      <!-- Budgie Desktop -->
      <div class="cat-divider">
        <span class="cat-label">Budgie Desktop</span>
        <div class="cat-line"></div>
      </div>

      <div class="body-text">
        <p>Ubuntu Budgie uses the Budgie desktop environment — a feature-rich, modern desktop designed to stay out of the way and let you focus on what you do best. If you've ever used Windows or macOS it will feel immediately familiar.</p>
      </div>

      <div class="feature-pills">
        <div class="feature-pill">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
          Raven Sidebar
        </div>
        <div class="feature-pill">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>
          Notification Center
        </div>
        <div class="feature-pill">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/></svg>
          Night Light
        </div>
        <div class="feature-pill">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
          GNOME App Support
        </div>
        <div class="feature-pill">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
          Highly Customisable
        </div>
      </div>

      <!-- Key Applications -->
      <div class="cat-divider">
        <span class="cat-label">Key Applications</span>
        <div class="cat-line"></div>
      </div>

      <div class="app-grid">
        <div class="app-card">
          <img src="img/applications/gnome-files.svg" alt="Nemo" />
          <div class="app-name">Nemo</div>
          <div class="app-role">File Manager</div>
        </div>
        <div class="app-card">
          <img src="img/applications/firefox.svg" alt="Firefox" />
          <div class="app-name">Firefox</div>
          <div class="app-role">Web Browser</div>
        </div>
        <div class="app-card">
          <img src="img/applications/libreoffice.svg" alt="LibreOffice" />
          <div class="app-name">LibreOffice</div>
          <div class="app-role">Office Suite</div>
        </div>
        <div class="app-card">
          <img src="img/applications/gnome-software.svg" alt="AppCenter" />
          <div class="app-name">AppCenter</div>
          <div class="app-role">Software Store</div>
        </div>
        <div class="app-card">
