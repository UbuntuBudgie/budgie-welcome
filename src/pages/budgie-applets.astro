<script is:inline>
(function () {
  function cmd(command) { console.log('cmd:', command); }
  window.cmd = cmd;

  document.addEventListener('DOMContentLoaded', function () {
    var cards = Array.from(document.querySelectorAll('.applet-card'));
    var grid = document.getElementById('cardsGrid');
    var empty = document.getElementById('emptyState');
    var emptyQuery = document.getElementById('emptyQuery');
    var countLabel = document.getElementById('countLabel');
    var searchInput = document.getElementById('searchInput');

    function updateCount(visible) {
      countLabel.textContent = visible + ' of ' + cards.length + ' applets';
    }
    updateCount(cards.length);

    /* ── Search / filter ── */
    searchInput.addEventListener('input', function () {
      var q = searchInput.value.trim().toLowerCase();
      var visible = 0;
      cards.forEach(function (card) {
        var haystack = (card.dataset.name || '') + ' ' + (card.querySelector('.card-name').textContent).toLowerCase();
        var show = !q || haystack.indexOf(q) !== -1;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      updateCount(visible);
      if (visible === 0) {
        empty.classList.add('visible');
        emptyQuery.textContent = searchInput.value.trim();
        grid.style.display = 'none';
      } else {
        empty.classList.remove('visible');
        grid.style.display = '';
      }
    });

    /* ── Install / Remove toggling ── */
    cards.forEach(function (card) {
      var installBtn = card.querySelector('.btn-install');
      var removeBtn  = card.querySelector('.btn-remove');

      installBtn.addEventListener('click', function () {
        card.classList.add('applying');
        // simulate async install
        setTimeout(function () {
          card.classList.remove('applying');
          card.classList.add('installed');
          cmd('install?' + (card.querySelector('.card-name').textContent.trim().toLowerCase().replace(/\s+/g, '-')));
        }, 1800);
      });

      removeBtn.addEventListener('click', function () {
        card.classList.remove('installed');
        cmd('remove?' + (card.querySelector('.card-name').textContent.trim().toLowerCase().replace(/\s+/g, '-')));
      });
    });

    /* ── Desktop Settings button ── */
    document.getElementById('settingsBtn').addEventListener('click', function () {
      cmd('budgie-desktop-settings');
    });
  });
})();
</script>
