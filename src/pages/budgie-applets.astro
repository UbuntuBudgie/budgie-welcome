---
// Ubuntu Budgie Welcome — Budgie Desktop Extras
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome — Budgie Desktop Extras</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --accent-light:  #dbeafe;
      --hover-bg:      #ebebeb;
      --card-border:   #e8e8e8;
      --green:         #16a34a;
      --green-light:   #dcfce7;
      --red:           #dc2626;
      --red-light:     #fee2e2;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-lg:     14px;
      --radius-win:    14px;
      --font:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); font-family: var(--font);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 900px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 700px; min-height: 480px;
      background: var(--win-bg); border-radius: var(--radius-win);
      box-shadow: var(--shadow-win); overflow: hidden;
      display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 8px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .back-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--accent); font-family: var(--font);
      font-size: 13px; font-weight: 500;
      padding: 4px 6px 4px 2px; border-radius: var(--radius-sm);
      transition: background .12s; text-decoration: none;
    }
    .back-btn:hover { background: var(--accent-light); }
    .back-btn svg { width: 16px; height: 16px; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-size: 13px; font-weight: 500;
      color: var(--text-secondary); letter-spacing: -.01em; pointer-events: none;
    }

    /* ── Toolbar (search + settings btn) ── */
    .toolbar {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 20px; border-bottom: 1px solid var(--card-border);
      background: var(--win-bg); flex-shrink: 0;
    }
    .search-wrap {
      flex: 1; position: relative;
    }
    .search-wrap svg {
      position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
      width: 14px; height: 14px; color: var(--text-tertiary); pointer-events: none;
    }
    .search-input {
      width: 100%; padding: 7px 12px 7px 32px;
      border: 1px solid var(--card-border); border-radius: var(--radius-sm);
      font-family: var(--font); font-size: 13px; color: var(--text-primary);
      background: #fafafa; outline: none;
      transition: border-color .12s, box-shadow .12s;
    }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(37,99,235,.1); background: #fff; }
    .search-input::placeholder { color: var(--text-tertiary); }

    .settings-btn {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 7px 14px; background: var(--accent); color: #fff;
      font-family: var(--font); font-size: 12.5px; font-weight: 500;
      border-radius: var(--radius-sm); border: none; cursor: pointer;
      white-space: nowrap; transition: background .12s;
      flex-shrink: 0;
    }
    .settings-btn:hover { background: #1d4ed8; }
    .settings-btn svg { width: 14px; height: 14px; }

    .count-label {
      font-size: 12px; color: var(--text-tertiary); white-space: nowrap;
      flex-shrink: 0;
    }

    /* ── Scroll grid ── */
    .scroll-body {
      flex: 1; overflow-y: auto; min-height: 0;
      padding: 16px 20px 20px;
    }
    .scroll-body::-webkit-scrollbar { width: 6px; }
    .scroll-body::-webkit-scrollbar-track { background: transparent; }
    .scroll-body::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .scroll-body::-webkit-scrollbar-thumb:hover { background: #aaa; }

    /* empty state */
    .empty-state {
      display: none; flex-direction: column; align-items: center;
      justify-content: center; padding: 48px 20px; gap: 10px;
      color: var(--text-tertiary);
    }
    .empty-state.visible { display: flex; }
    .empty-state svg { width: 36px; height: 36px; opacity: .4; }
    .empty-state p { font-size: 13px; }

    /* ── Cards grid ── */
    .cards-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
    }

    /* ── Applet card ── */
    .applet-card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-lg); overflow: hidden;
      display: flex; flex-direction: column;
      transition: box-shadow .14s, transform .12s;
      animation: fadeUp .24s ease both;
    }
    .applet-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }

    /* screenshot */
    .card-thumb {
      height: 120px; overflow: hidden; background: #f0f0f0;
      flex-shrink: 0; position: relative;
    }
    .card-thumb img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform .3s ease;
    }
    .applet-card:hover .card-thumb img { transform: scale(1.04); }

    /* body */
    .card-body {
      padding: 11px 12px 8px; flex: 1; display: flex; flex-direction: column; gap: 4px;
    }
    .card-name { font-size: 13px; font-weight: 600; color: var(--text-primary); line-height: 1.3; }
    .card-desc { font-size: 11.5px; color: var(--text-secondary); line-height: 1.55; flex: 1; }

    /* actions footer */
    .card-footer {
      display: flex; border-top: 1px solid var(--card-border); flex-shrink: 0;
    }
    .card-btn {
      flex: 1; padding: 8px 10px;
      display: flex; align-items: center; justify-content: center; gap: 5px;
      font-family: var(--font); font-size: 12px; font-weight: 500;
      border: none; cursor: pointer; transition: background .12s;
    }
    .card-btn svg { width: 12px; height: 12px; }
    .card-btn + .card-btn { border-left: 1px solid var(--card-border); }

    .btn-install { background: var(--green-light); color: var(--green); }
    .btn-install:hover { background: #bbf7d0; }
    .btn-remove  { background: var(--red-light);   color: var(--red);   display: none; }
    .btn-remove:hover  { background: #fecaca; }
    .btn-applying { background: #fafafa; color: var(--text-tertiary); display: none; pointer-events: none; }

    /* installed state */
    .applet-card.installed .btn-install  { display: none; }
    .applet-card.installed .btn-remove   { display: flex; }
    .applet-card.installed .card-thumb::after {
      content: '✓ Installed';
      position: absolute; top: 7px; right: 7px;
      padding: 2px 8px; border-radius: 20px;
      background: var(--green-light); color: var(--green);
      font-size: 10px; font-weight: 700; letter-spacing: .04em;
      border: 1px solid rgba(22,163,74,.2);
    }
    .applet-card.applying .btn-install  { display: none; }
    .applet-card.applying .btn-remove   { display: none; }
    .applet-card.applying .btn-applying { display: flex; }

    /* ── Spinner animation ── */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner-icon {
      width: 12px; height: 12px; border: 2px solid #d1d1d1;
      border-top-color: var(--text-tertiary); border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    /* ── Win Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 24px; border-top: 1px solid var(--card-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-secondary);
    }
    .discourse-link img { height: 18px; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: var(--hover-bg); color: var(--text-primary); }
    .social-link svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<div class="window">

  <!-- Title Bar -->
  <div class="titlebar">
    <a href="index" class="back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
      </svg>
      Back
    </a>
    <span class="titlebar-label">Budgie Desktop Extras</span>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
      </svg>
      <input type="text" class="search-input" id="searchInput" placeholder="Search applets…" />
    </div>
    <span class="count-label" id="countLabel"></span>
    <button class="settings-btn" id="settingsBtn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
      </svg>
      Desktop Settings
    </button>
  </div>

  <!-- Grid -->
  <div class="scroll-body" id="scrollBody">
    <div class="cards-grid" id="cardsGrid">

      <!-- macro: each card has data-name for search -->

      <div class="applet-card" data-name="haste applet post text code prose services">
        <div class="card-thumb"><img src="img/screenshots/haste-applet.jpg" alt="Haste Applet" /></div>
        <div class="card-body">
          <div class="card-name">Haste Applet</div>
          <div class="card-desc">Post any text — code or prose — to various paste services directly from your desktop panel.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="media applet player music audio panel control">
        <div class="card-thumb"><img src="img/screenshots/mediaplayer-applet.jpg" alt="Media Applet" /></div>
        <div class="card-body">
          <div class="card-name">Media Player Applet</div>
          <div class="card-desc">Control all of your playing media from the Budgie panel without switching windows.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="lightpad applet launcher fullscreen applications">
        <div class="card-thumb"><img src="img/screenshots/lightpad-applet.jpg" alt="Lightpad Applet" /></div>
        <div class="card-body">
          <div class="card-name">Lightpad Applet</div>
          <div class="card-desc">A full-screen application launcher overlay for quick app access from the panel.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="user indicator session manage login logout panel">
        <div class="card-thumb"><img src="img/screenshots/user-indicator-redux-applet.jpg" alt="User Indicator Applet" /></div>
        <div class="card-body">
          <div class="card-name">User Indicator Applet</div>
          <div class="card-desc">Manage the user session — log out, switch users — directly from the Budgie panel.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="performance gauge cpu memory storage panel monitor">
        <div class="card-thumb"><img src="img/screenshots/performance-gauge-applet.jpg" alt="Performance Gauge" /></div>
        <div class="card-body">
          <div class="card-name">Performance Gauge</div>
          <div class="card-desc">Shows a CPU, memory or storage gauge directly on your Budgie panel at a glance.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="screenshot applet capture screen image utility">
        <div class="card-thumb"><img src="img/screenshots/screenshot-applet.jpg" alt="Screenshot Applet" /></div>
        <div class="card-body">
          <div class="card-name">Screenshot Applet</div>
          <div class="card-desc">Advanced screenshot utility for capturing, organizing and sharing screenshots from the panel.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="clipboard applet manager store content copy paste">
        <div class="card-thumb"><img src="img/screenshots/clipboard-applet.jpg" alt="Clipboard Applet" /></div>
        <div class="card-body">
          <div class="card-name">Clipboard Applet</div>
          <div class="card-desc">A clipboard manager to store and manage clipboard content — never lose a copied item again.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="calendar applet date time clock popover">
        <div class="card-thumb"><img src="img/screenshots/calendar-applet.jpg" alt="Calendar Applet" /></div>
        <div class="card-body">
          <div class="card-name">Calendar Applet</div>
          <div class="card-desc">Shows the date and time in the panel; click to reveal a full calendar popover.</div>
        </div>
        <div class="card-footer">
          <button class="card-btn btn-install"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install</button>
          <button class="card-btn btn-applying"><div class="spinner-icon"></div>Applying…</button>
          <button class="card-btn btn-remove"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Remove</button>
        </div>
      </div>

      <div class="applet-card" data-name="network applet connectivity wifi ethernet internet">
        <div class="card-thumb"><img src="img/screenshots/network-applet.jpg" alt="Network Applet" /></div>
        <div class="card-body">
          <div class="card-name">Network Applet</div>
          <div class="card-desc">Network connectivity management applet for the Budgie panel — Wi-Fi, VPN and more.</div>
        </div>
        <div class="card-footer">
