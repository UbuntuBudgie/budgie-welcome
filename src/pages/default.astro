<script is:inline>
(function () {
  function cmd(c) { console.log('cmd:', c); }
  window.cmd = cmd;

  document.addEventListener('DOMContentLoaded', function () {

    /* ── Tab switching ── */
    document.querySelectorAll('.tab-btn[data-tab]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        document.querySelectorAll('.tab-page').forEach(function (p) { p.classList.remove('active'); });
        btn.classList.add('active');
        var page = document.getElementById('page-' + btn.dataset.tab);
        if (page) page.classList.add('active');
        document.querySelector('.scroll-body').scrollTop = 0;
      });
    });

    /* ── Theme split-button dropdowns ── */
    document.querySelectorAll('.split-arrow').forEach(function (arrow) {
      arrow.addEventListener('click', function (e) {
        e.stopPropagation();
        var menu = arrow.nextElementSibling;
        var isOpen = menu.classList.toggle('open');
        arrow.classList.toggle('open', isOpen);
        // close all other open menus
        document.querySelectorAll('.theme-menu.open').forEach(function (m) {
          if (m !== menu) { m.classList.remove('open'); m.previousElementSibling.classList.remove('open'); }
        });
      });
    });

    /* close dropdowns on outside click */
    document.addEventListener('click', function () {
      document.querySelectorAll('.theme-menu.open').forEach(function (m) {
        m.classList.remove('open');
        m.previousElementSibling.classList.remove('open');
      });
    });

    /* ── Install buttons ── */
    document.querySelectorAll('.install-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = btn.closest('.item-card');
        var badge = card.querySelector('.applying-badge');
        var applyGroup = card.querySelector('.apply-group');
        var applyBtn   = card.querySelector('.apply-btn');
        btn.style.display = 'none';
        if (badge) badge.classList.add('visible');
        cmd('install?' + btn.dataset.install);
        setTimeout(function () {
          if (badge) badge.classList.remove('visible');
          if (applyGroup) applyGroup.style.display = '';
          if (applyBtn)   applyBtn.style.display = '';
        }, 1800);
      });
    });

    /* ── Makeover main button ── */
    document.querySelectorAll('.split-main[data-makeover]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        showApplying(btn.closest('.item-card'));
        cmd('makeover?' + btn.dataset.makeover);
      });
    });

    /* ── Theme menu items ── */
    document.querySelectorAll('.theme-menu-item[data-makeover]').forEach(function (btn) {
      btn.addEventListener('click', function () { showApplying(btn.closest('.item-card')); cmd('makeover?' + btn.dataset.makeover); });
    });
    document.querySelectorAll('.theme-menu-item[data-theme]').forEach(function (btn) {
      btn.addEventListener('click', function () { showApplying(btn.closest('.item-card')); cmd('theme?' + btn.dataset.theme); });
    });
    document.querySelectorAll('.theme-menu-item[data-font]').forEach(function (btn) {
      btn.addEventListener('click', function () { showApplying(btn.closest('.item-card')); cmd('font?' + btn.dataset.font); });
    });
    document.querySelectorAll('.theme-menu-item[data-icon]').forEach(function (btn) {
      btn.addEventListener('click', function () { showApplying(btn.closest('.item-card')); cmd('icon?' + btn.dataset.icon); });
    });
    document.querySelectorAll('.theme-menu-item[data-desktop]').forEach(function (btn) {
      btn.addEventListener('click', function () { showApplying(btn.closest('.item-card')); cmd('desktop?' + btn.dataset.desktop); });
    });

    /* ── Layout apply buttons ── */
    document.querySelectorAll('.apply-btn[data-layout]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        showApplying(btn.closest('.item-card'));
        cmd('layout?' + btn.dataset.layout);
      });
    });

    /* ── Panel reset ── */
    document.getElementById('panelResetBtn').addEventListener('click', function () {
      document.getElementById('panelApplying').classList.add('visible');
      cmd('panel-reset');
      setTimeout(function () { document.getElementById('panelApplying').classList.remove('visible'); }, 2000);
    });

    function showApplying(card) {
      var badge = card.querySelector('.applying-badge');
      if (!badge) return;
      badge.classList.add('visible');
      setTimeout(function () { badge.classList.remove('visible'); }, 2000);
    }
  });
})();
</script>
</body>
</html>