---
// Ubuntu Budgie Welcome — Budgie Makeovers & Layouts
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome — Themes &amp; Layouts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --accent-light:  #dbeafe;
      --hover-bg:      #ebebeb;
      --card-border:   #e8e8e8;
      --green:         #16a34a;
      --green-light:   #dcfce7;
      --amber:         #d97706;
      --amber-light:   #fef3c7;
      --red:           #dc2626;
      --red-light:     #fee2e2;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-lg:     14px;
      --radius-win:    14px;
      --font:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); font-family: var(--font);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 900px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 700px; min-height: 480px;
      background: var(--win-bg); border-radius: var(--radius-win);
      box-shadow: var(--shadow-win); overflow: hidden;
      display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 8px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .back-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--accent); font-family: var(--font);
      font-size: 13px; font-weight: 500;
      padding: 4px 6px 4px 2px; border-radius: var(--radius-sm);
      transition: background .12s; text-decoration: none;
    }
    .back-btn:hover { background: var(--accent-light); }
    .back-btn svg { width: 16px; height: 16px; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-size: 13px; font-weight: 500;
      color: var(--text-secondary); letter-spacing: -.01em; pointer-events: none;
    }

    /* ── Tab bar ── */
    .tab-bar {
      display: flex; gap: 2px; padding: 0 20px;
      background: var(--bar-bg); border-bottom: 1px solid var(--bar-border);
      flex-shrink: 0;
    }
    .tab-btn {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 16px;
      font-family: var(--font); font-size: 13px; font-weight: 500;
      color: var(--text-tertiary); cursor: pointer;
      background: none; border: none;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
      position: relative; top: 1px; white-space: nowrap;
    }
    .tab-btn:hover { color: var(--text-secondary); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ── Tab pages ── */
    .tab-page { display: none; }
    .tab-page.active { display: block; animation: fadeUp .2s ease both; }

    /* ── Scroll body ── */
    .scroll-body {
      flex: 1; overflow-y: auto; min-height: 0;
    }
    .scroll-body::-webkit-scrollbar { width: 6px; }
    .scroll-body::-webkit-scrollbar-track { background: transparent; }
    .scroll-body::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .scroll-body::-webkit-scrollbar-thumb:hover { background: #aaa; }

    /* ── Page header ── */
    .page-header { padding: 20px 24px 14px; border-bottom: 1px solid var(--card-border); }
    .page-header h2 { font-size: 17px; font-weight: 600; color: var(--text-primary); letter-spacing: -.01em; margin-bottom: 3px; }
    .page-header p  { font-size: 12.5px; color: var(--text-secondary); line-height: 1.55; }

    /* ── Cards grid ── */
    .cards-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
      padding: 18px 24px 220px;
      overflow: visible;
    }

    /* ── Theme / layout card ── */
    .item-card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-lg); overflow: visible;
      display: flex; flex-direction: column;
      transition: box-shadow .14s, transform .12s;
      animation: fadeUp .24s ease both;
    }
    .item-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }

    /* thumbnail — clip here, not on the whole card */
    .card-thumb {
      height: 120px; overflow: hidden; background: #e8e8e8; flex-shrink: 0;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
    .card-thumb img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform .3s ease;
    }
    .item-card:hover .card-thumb img { transform: scale(1.03); }

    /* card body */
    .card-body { padding: 10px 12px 12px; flex: 1; }
    .card-name  { font-size: 13px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; }

    /* ── Action buttons row ── */
    .card-actions { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }

    /* base button */
    .btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 11px; border-radius: var(--radius-sm);
      font-family: var(--font); font-size: 12px; font-weight: 500;
      cursor: pointer; border: none; transition: background .12s, transform .1s;
      white-space: nowrap;
    }
    .btn:active { transform: scale(.97); }
    .btn svg { width: 13px; height: 13px; }

    .btn-install  { background: var(--green-light);  color: var(--green);  border: 1px solid rgba(22,163,74,.25); }
    .btn-install:hover  { background: #bbf7d0; border-color: var(--green); }
    .btn-apply    { background: var(--accent-light); color: var(--accent); border: 1px solid rgba(37,99,235,.2); }
    .btn-apply:hover    { background: #bfdbfe; border-color: var(--accent); }
    .btn-reset    { background: var(--amber-light);  color: var(--amber);  border: 1px solid rgba(217,119,6,.2); }
    .btn-reset:hover    { background: #fde68a; border-color: var(--amber); }

    /* split apply+dropdown for themes */
    .split-wrap { position: relative; display: inline-flex; }
    .split-main {
      border-radius: var(--radius-sm) 0 0 var(--radius-sm);
      border-right: none !important;
    }
    .split-arrow {
      display: inline-flex; align-items: center; justify-content: center;
      width: 26px; padding: 0;
      background: var(--accent-light); color: var(--accent);
      border: 1px solid rgba(37,99,235,.2);
      border-left: 1px solid rgba(37,99,235,.15);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      cursor: pointer; font-size: 0; transition: background .12s;
    }
    .split-arrow:hover { background: #bfdbfe; }
    .split-arrow svg { width: 11px; height: 11px; transition: transform .18s; }
    .split-arrow.open svg { transform: rotate(180deg); }

    /* dropdown — position absolute, grid has padding-bottom room */
    .theme-menu {
      display: none; position: absolute;
      top: calc(100% + 4px); left: 0; z-index: 200;
      min-width: 190px;
      background: var(--win-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-md);
      overflow: hidden;
      animation: fadeUp .14s ease both;
    }
    .theme-menu.open { display: block; }
    .theme-menu-item {
      display: flex; align-items: center; gap: 8px;
      padding: 8px 13px; width: 100%;
      background: none; border: none; cursor: pointer;
      font-family: var(--font); font-size: 12.5px; color: var(--text-primary);
      text-align: left; transition: background .1s, color .1s;
    }
    .theme-menu-item:hover { background: var(--hover-bg); color: var(--accent); }
    .theme-menu-item svg { width: 13px; height: 13px; color: var(--text-tertiary); flex-shrink: 0; }
    .theme-menu-item:hover svg { color: var(--accent); }
    .theme-menu-divider { height: 1px; background: var(--card-border); margin: 3px 0; }

    /* applying spinner */
    @keyframes spin { to { transform: rotate(360deg); } }
    .applying-badge {
      display: none; align-items: center; gap: 6px;
      font-size: 11.5px; color: var(--text-tertiary);
    }
    .applying-badge.visible { display: inline-flex; }
    .spin-ring {
      width: 12px; height: 12px; border: 2px solid #d1d1d1;
      border-top-color: var(--text-tertiary); border-radius: 50%;
      animation: spin .7s linear infinite;
    }

    /* ── Restore Panels section ── */
    .restore-section { padding: 24px; }
    .restore-card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-lg); padding: 20px 22px;
    }
    .restore-card h3 { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; }
    .restore-card p  { font-size: 13px; color: var(--text-secondary); line-height: 1.65; margin-bottom: 14px; }
    .restore-warn {
      display: flex; align-items: flex-start; gap: 9px;
      padding: 10px 13px; border-radius: var(--radius-sm);
      background: var(--amber-light); border: 1px solid rgba(217,119,6,.2); color: #92400e;
      font-size: 12.5px; line-height: 1.55; margin-bottom: 16px;
    }
    .restore-warn svg { width: 14px; height: 14px; flex-shrink: 0; margin-top: 1px; }

    /* ── Win Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 24px; border-top: 1px solid var(--card-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-secondary);
    }
    .discourse-link img { height: 18px; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: var(--hover-bg); color: var(--text-primary); }
    .social-link svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<div class="window">

  <!-- Title Bar -->
  <div class="titlebar">
    <a href="index" class="back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
      </svg>
      Back
    </a>
    <span class="titlebar-label">Budgie Makeovers &amp; Layouts</span>
  </div>

  <!-- Tab Bar -->
  <div class="tab-bar">
    <button class="tab-btn active" data-tab="themes">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z"/></svg>
      Switch Appearance
    </button>
    <button class="tab-btn" data-tab="layout">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z"/></svg>
      Desktop Layout
    </button>
    <button class="tab-btn" data-tab="settings">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
      Panel Settings
    </button>
  </div>

  <!-- Scrollable body -->
  <div class="scroll-body">

    <!-- ══ THEMES TAB ══ -->
    <div class="tab-page active" id="page-themes">
      <div class="page-header">
        <h2>Switch Appearance</h2>
        <p>Choose a theme to change your desktop appearance — including icons, fonts, wallpaper, and GTK style — with a single click.</p>
      </div>
      <div class="cards-grid">

        <!-- helper macro: each card has data-id for the cmd() calls -->

        <div class="item-card" data-id="pocillo">
          <div class="card-thumb"><img src="img/screenshots/pocillo-style.jpg" alt="Pocillo theme" /></div>
          <div class="card-body">
            <div class="card-name">Pocillo</div>
            <div class="card-actions">
              <button class="btn btn-install install-btn" data-install="pocillo-theme">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>Install
              </button>
              <div class="split-wrap apply-group" style="display:none;">
                <button class="btn btn-apply split-main" data-makeover="pocillo">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>Apply Makeover
                </button>
                <button class="split-arrow" aria-label="More options"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg></button>
                <div class="theme-menu">
                  <button class="theme-menu-item" data-makeover="pocillo"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42"/></svg>Apply makeover</button>
                  <div class="theme-menu-divider"></div>
                  <button class="theme-menu-item" data-theme="pocillo"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197"/></svg>Apply theme</button>
                  <button class="theme-menu-item" data-font="pocillo"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.744h-.753v8.25m0 0h-.75v8.25m.75-8.25H7.5m-1.503 0H6m0 0h6m0 0h.75v-8.25m0 0h-.75M12 3.744h6m0 0h.75v8.25m0 0h-.75M18 12H6"/></svg>Apply fonts</button>
                  <button class="theme-menu-item" data-icon="pocillo"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>Apply icons</button>
                  <button class="theme-menu-item" data-desktop="pocillo"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3"/></svg>Make desktop changes</button>
                </div>
              </div>
              <span class="applying-badge"><div class="spin-ring"></div>Applying…</span>
            </div>
          </div>
        </div>

        <div class="item-card" data-id="mojave">
          <div class="card-thumb"><img src="img/screenshots/mojave-style.jpg" alt="Mojave theme" /></div>
          <div class="card-body">
            <div class="card-name">Mojave</div>
