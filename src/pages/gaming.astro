---
// Ubuntu Budgie Welcome — Gaming, dark gaming aesthetic
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome — Gaming</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --surface:       #fafafa;
      --surface-2:     #f5f5f5;
      --surface-3:     #efefef;
      --border:        #e8e8e8;
      --border-soft:   #f0f0f0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --accent-light:  #dbeafe;
      --green:         #16a34a;
      --green-light:   #dcfce7;
      --red:           #dc2626;
      --red-light:     #fee2e2;
      --amber:         #d97706;
      --amber-light:   #fef3c7;
      --purple:        #7c3aed;
      --purple-light:  #ede9fe;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-lg:     14px;
      --radius-win:    14px;
      --font-ui:       'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-display:  'Space Grotesk', sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg);
      font-family: var(--font-ui);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 920px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 700px; min-height: 500px;
      background: var(--win-bg);
      border-radius: var(--radius-win);
      box-shadow: var(--shadow-win);
      overflow: hidden; display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 10px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .back-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--accent); font-family: var(--font-ui);
      font-size: 13px; font-weight: 500;
      padding: 4px 8px 4px 2px; border-radius: var(--radius-sm);
      transition: background .12s; text-decoration: none;
    }
    .back-btn:hover { background: var(--accent-light); }
    .back-btn svg { width: 16px; height: 16px; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-family: var(--font-display);
      font-size: 13px; font-weight: 600;
      color: var(--text-secondary); letter-spacing: .01em; pointer-events: none;
    }
    /* decorative accent dots */
    .titlebar-dots { margin-left: auto; display: flex; gap: 5px; align-items: center; }
    .titlebar-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--border); }
    .titlebar-dot.a { background: #ff5f57; }
    .titlebar-dot.b { background: #febc2e; }
    .titlebar-dot.c { background: #28c840; }

    /* ── Tab bar ── */
    .tab-bar {
      display: flex; gap: 2px; padding: 0 20px;
      background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      flex-shrink: 0;
    }
    .tab-btn {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 16px;
      font-family: var(--font-ui); font-size: 13px; font-weight: 500;
      color: var(--text-tertiary); cursor: pointer;
      background: none; border: none;
      border-bottom: 2px solid transparent;
      transition: color .15s, border-color .15s;
      position: relative; top: 1px; white-space: nowrap;
    }
    .tab-btn .tab-icon { font-size: 15px; }
    .tab-btn:hover { color: var(--text-secondary); }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    /* ── Body: full scrollable content ── */
    .body-scroll {
      flex: 1; overflow-y: auto; min-height: 0;
      background: var(--win-bg);
    }
    .body-scroll::-webkit-scrollbar { width: 6px; }
    .body-scroll::-webkit-scrollbar-track { background: transparent; }
    .body-scroll::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .body-scroll::-webkit-scrollbar-thumb:hover { background: #aaa; }

    /* ── Tab pages ── */
    .tab-page { display: none; padding: 24px 24px 28px; }
    .tab-page.active { display: block; animation: fadeUp .2s ease both; }

    /* ── Section header ── */
    .section-intro { margin-bottom: 20px; }
    .section-intro h2 {
      font-family: var(--font-display);
      font-size: 18px; font-weight: 700;
      color: var(--text-primary); letter-spacing: -.01em; margin-bottom: 4px;
    }
    .section-intro p { font-size: 13px; color: var(--text-secondary); line-height: 1.55; }

    /* ── Category divider ── */
    .cat-divider {
      display: flex; align-items: center; gap: 10px; margin: 24px 0 14px;
    }
    .cat-label {
      font-size: 10px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--text-tertiary); white-space: nowrap;
    }
    .cat-line { flex: 1; height: 1px; background: var(--border-soft); }

    /* ── Client grid — 2 col ── */
    .client-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* ── Client card ── */
    .client-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      transition: border-color .2s, box-shadow .2s;
    }
    .client-card:hover {
      border-color: var(--accent);
      box-shadow: var(--shadow-md);
    }
    .client-card-img {
      width: 100%; height: 90px;
      display: flex; align-items: center; justify-content: center;
      background: var(--surface-2);
      border-bottom: 1px solid var(--border-soft);
      padding: 16px;
    }
    .client-card-img img { max-height: 58px; max-width: 100%; object-fit: contain; }
    .client-card-body { padding: 14px 16px 12px; }
    .client-card-name {
      font-family: var(--font-display);
      font-size: 14px; font-weight: 600;
      color: var(--text-primary); margin-bottom: 5px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .client-card-desc { font-size: 12px; color: var(--text-secondary); line-height: 1.55; margin-bottom: 12px; }
    .client-actions { display: flex; gap: 6px; flex-wrap: wrap; }

    /* ── Tool grid — 3 col ── */
    .tool-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .tool-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 14px 12px;
      display: flex; flex-direction: column; gap: 8px;
      transition: border-color .18s, box-shadow .18s;
    }
    .tool-card:hover { border-color: var(--accent); box-shadow: var(--shadow-sm); }
    .tool-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--surface-2);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .tool-icon img { width: 32px; height: 32px; object-fit: contain; }
    .tool-name {
      font-family: var(--font-display);
      font-size: 13px; font-weight: 600; color: var(--text-primary);
    }
    .tool-desc { font-size: 11.5px; color: var(--text-secondary); line-height: 1.55; flex: 1; }
    .tool-actions { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 2px; }
    .tool-help-link {
      font-size: 11px; color: var(--text-tertiary); text-decoration: none;
      cursor: pointer; transition: color .12s;
    }
    .tool-help-link:hover { color: var(--accent); }

    /* ── Game grid — 3 col ── */
    .game-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .game-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      display: flex; flex-direction: column;
      transition: border-color .18s, transform .18s, box-shadow .18s;
    }
    .game-card:hover {
      border-color: var(--accent);
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }
    .game-thumb {
      width: 100%; height: 110px; overflow: hidden;
      background: var(--surface-2); position: relative;
    }
    .game-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .game-thumb-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-size: 32px;
    }
    .game-genre {
      position: absolute; top: 6px; right: 6px;
      padding: 2px 7px; border-radius: 20px;
      font-size: 9.5px; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
      background: rgba(0,0,0,.52); color: #fff;
    }
    .free-badge {
      position: absolute; top: 6px; left: 6px;
      padding: 2px 7px; border-radius: 20px;
      font-size: 9.5px; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
      background: var(--green-light); color: var(--green);
      border: 1px solid rgba(22,163,74,.25);
    }
    .game-body { padding: 12px 12px 10px; flex: 1; display: flex; flex-direction: column; gap: 6px; }
    .game-name {
      font-family: var(--font-display);
      font-size: 13px; font-weight: 600; color: var(--text-primary);
    }
    .game-desc { font-size: 11.5px; color: var(--text-secondary); line-height: 1.5; flex: 1; }
    .game-actions { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 4px; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 11px; border-radius: var(--radius-sm);
      font-family: var(--font-ui); font-size: 11.5px; font-weight: 500;
      cursor: pointer; border: none; transition: all .12s;
      text-decoration: none; white-space: nowrap;
    }
    .btn:active { transform: scale(.97); }
    .btn img { width: 13px; height: 13px; object-fit: contain; }

    .btn-install  { background: var(--green-light); color: var(--green); border: 1px solid rgba(22,163,74,.25); }
    .btn-install:hover  { background: #bbf7d0; border-color: var(--green); }
    .btn-remove   { background: var(--red-light); color: var(--red); border: 1px solid rgba(220,38,38,.2); }
    .btn-remove:hover   { background: #fecaca; border-color: var(--red); }
    .btn-launch   { background: var(--purple-light); color: var(--purple); border: 1px solid rgba(124,58,237,.2); }
    .btn-launch:hover   { background: #ddd6fe; border-color: var(--purple); }
    .btn-watch    { background: #fee2e2; color: #b91c1c; border: 1px solid rgba(185,28,28,.18); }
    .btn-watch:hover    { background: #fecaca; border-color: #b91c1c; }
    .btn-neutral  { background: var(--surface-2); color: var(--text-secondary); border: 1px solid var(--border); }
    .btn-neutral:hover  { background: var(--surface-3); color: var(--text-primary); }
    .btn-neon     { background: var(--accent-light); color: var(--accent); border: 1px solid rgba(37,99,235,.2); }
    .btn-neon:hover     { background: #bfdbfe; border-color: var(--accent); }

    /* ── Help link ── */
    .help-link {
      display: inline-flex; align-items: center; gap: 3px;
      font-size: 11px; color: var(--text-tertiary);
      cursor: pointer; background: none; border: none;
      padding: 0; font-family: var(--font-ui); transition: color .12s;
    }
    .help-link:hover { color: var(--accent); }
    .help-link svg { width: 12px; height: 12px; }

    /* ── Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 22px; border-top: 1px solid var(--bar-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-tertiary);
    }
    .discourse-link img { height: 16px; opacity: .7; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 26px; height: 26px; border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: #ebebeb; color: var(--text-primary); }
    .social-link svg { width: 13px; height: 13px; }
  </style>
</head>
<body>
<div class="window">

  <!-- ── Title Bar ── -->
  <div class="titlebar">
    <a href="index" class="back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
      </svg>
      Back
    </a>
    <span class="titlebar-label">Gaming</span>
    <div class="titlebar-dots">
      <div class="titlebar-dot a"></div>
      <div class="titlebar-dot b"></div>
      <div class="titlebar-dot c"></div>
    </div>
  </div>

  <!-- ── Tab Bar ── -->
  <div class="tab-bar">
    <button class="tab-btn active" data-tab="clients">
      <span class="tab-icon">🎮</span> Gaming Clients
    </button>
    <button class="tab-btn" data-tab="tools">
      <span class="tab-icon">🔧</span> Gaming Tools
    </button>
    <button class="tab-btn" data-tab="games">
      <span class="tab-icon">🕹️</span> Games List
    </button>
  </div>

  <!-- ── Scrollable Content ── -->
  <div class="body-scroll">

    <!-- ══════════ CLIENTS ══════════ -->
    <div class="tab-page active" id="page-clients">
      <div class="section-intro">
        <h2>Gaming Clients</h2>
        <p>Download, install and manage your games from one place.</p>
      </div>

      <div class="client-grid">

        <!-- Steam -->
        <div class="client-card" id="steamid">
          <div class="client-card-img">
            <img src="img/logos/steam_app_icon.png" alt="Steam" />
          </div>
          <div class="client-card-body">
            <div class="client-card-name">
              Steam
              <button class="help-link" data-cmd="link?https://help.steampowered.com/en/">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
                Docs
              </button>
            </div>
            <div class="client-card-desc">The ultimate destination for playing, discussing, and creating games. Thousands of Linux-native and Proton-compatible titles.</div>
            <div class="client-actions">
              <button class="btn btn-install" id="steam-install" data-cmd="install?steam">▼ Install</button>
              <button class="btn btn-remove"  id="steam-remove"  data-cmd="remove?steam">✕ Remove</button>
            </div>
          </div>
        </div>

        <!-- Lutris -->
        <div class="client-card">
          <div class="client-card-img">
            <img src="img/logos/lutris.png" alt="Lutris" />
          </div>
          <div class="client-card-body">
            <div class="client-card-name">
              Lutris
              <button class="help-link" data-cmd="link?https://forums.lutris.net/t/very-brief-tutorial-on-manually-installing-a-game-in-lutris/2028">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
                Guide
              </button>
            </div>
            <div class="client-card-desc">Open gaming platform for Linux. Manage almost all your games — GOG, Epic, Humble Bundle, and more — in one place.</div>
            <div class="client-actions">
              <button class="btn btn-install" id="lutris-install" data-cmd="install?lutris">▼ Install</button>
              <button class="btn btn-remove"  id="lutris-remove"  data-cmd="remove?lutris">✕ Remove</button>
            </div>
          </div>
        </div>

        <!-- RetroArch -->
        <div class="client-card">
          <div class="client-card-img">
            <img src="img/logos/retroarch.jpg" alt="RetroArch" />
          </div>
          <div class="client-card-body">
            <div class="client-card-name">
              RetroArch
              <button class="help-link" data-cmd="link?https://www.retroarch.com/">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
                FAQ
              </button>
            </div>
            <div class="client-card-desc">A powerful frontend for emulators, game engines and media players. Play classic consoles on your modern machine.</div>
            <div class="client-actions">
              <button class="btn btn-install" id="retroarch-install" data-cmd="install?retroarch">▼ Install</button>
              <button class="btn btn-remove"  id="retroarch-remove"  data-cmd="remove?retroarch">✕ Remove</button>
            </div>
          </div>
        </div>

        <!-- MiniGalaxy -->
        <div class="client-card">
          <div class="client-card-img">
            <img src="img/screenshots/minigalaxy.jpg" alt="MiniGalaxy" style="height:90px;width:100%;object-fit:cover;" />
          </div>
          <div class="client-card-body">
            <div class="client-card-name">
              MiniGalaxy
              <button class="help-link" data-cmd="link?https://www.gog.com/galaxy">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
                GOG
              </button>
            </div>
            <div class="client-card-desc">A GOG client for Linux. Install, manage and update native and Windows games including DLCs straight from your GOG library.</div>
            <div class="client-actions">
              <button class="btn btn-install" id="minigalaxy-install" data-cmd="install?minigalaxy">▼ Install</button>
              <button class="btn btn-remove"  id="minigalaxy-remove"  data-cmd="remove?minigalaxy">✕ Remove</button>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ══════════ TOOLS ══════════ -->
    <div class="tab-page" id="page-tools">
      <div class="section-intro">
        <h2>Gaming Tools</h2>
        <p>Enhance your experience with peripherals, performance overlays, RGB control and streaming.</p>
      </div>

      <div class="cat-divider"><span class="cat-label">Peripherals</span><div class="cat-line"></div></div>
      <div class="tool-grid">

        <div class="tool-card">
          <div class="tool-icon"><img src="img/screenshots/piper-resolutionpage.png" alt="Piper" /></div>
          <div class="tool-name">Piper</div>
          <div class="tool-desc">GTK+ application to configure gaming mice using ratbagd. Fine-tune DPI, buttons and lighting on supported hardware.</div>
          <div class="tool-actions">
            <button class="btn btn-install" id="piper-install" data-cmd="install?piper">▼ Install</button>
            <button class="btn btn-remove"  id="piper-remove"  data-cmd="remove?piper">✕ Remove</button>
            <button class="help-link" data-cmd="link?https://github.com/libratbag/piper">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
              GitHub
            </button>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-icon"><img src="img/screenshots/cpufreq-applet.jpg" alt="CPU Freq" /></div>
          <div class="tool-name">CPU Frequency Applet</div>
          <div class="tool-desc">Control processor frequency (Sandy Bridge and newer) directly from the Budgie panel for instant performance switching.</div>
          <div class="tool-actions">
