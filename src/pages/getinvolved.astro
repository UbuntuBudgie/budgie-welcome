<script is:inline>
(function () {
  function cmd(command) { console.log('cmd:', command); }
  window.cmd = cmd;

  function checkConnection() {
    var banner = document.getElementById('offlineBanner');
    var failMsg = document.getElementById('reconnectFailed');
    fetch('https://example.com', { mode: 'no-cors' })
      .then(function () { banner.classList.remove('visible'); })
      .catch(function () {
        banner.classList.add('visible');
        setTimeout(function () { failMsg.style.display = 'block'; }, 5000);
      });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-cmd]').forEach(function (el) {
      el.addEventListener('click', function () { cmd(el.dataset.cmd); });
    });
    var retryBtn = document.getElementById('retryBtn');
    if (retryBtn) {
      retryBtn.addEventListener('click', function () {
        document.getElementById('reconnectFailed').style.display = 'none';
        checkConnection();
      });
    }
    checkConnection();
  });
})();
</script>
