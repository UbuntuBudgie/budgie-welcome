---
// Ubuntu Budgie Welcome — macOS-style, no sidebar
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --hover-bg:      #ebebeb;
      --card-border:   #e8e8e8;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-win:    14px;
      --font:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); font-family: var(--font);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 860px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 680px; min-height: 480px;
      background: var(--win-bg); border-radius: var(--radius-win);
      box-shadow: var(--shadow-win); overflow: hidden;
      display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 8px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .traffic-lights { display: flex; gap: 7px; align-items: center; }
    .tl {
      width: 12px; height: 12px; border-radius: 50%;
      cursor: default; transition: filter .15s;
    }
    .tl:hover { filter: brightness(.82); }
    .tl-close { background: #ff5f57; }
    .tl-min   { background: #febc2e; }
    .tl-max   { background: #28c840; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-size: 13px; font-weight: 500;
      color: var(--text-secondary); letter-spacing: -.01em; pointer-events: none;
    }

    /* ── Main ── */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }

    /* ── Hero ── */
    .hero {
      display: flex; flex-direction: column; align-items: center;
      padding: 28px 32px 18px; border-bottom: 1px solid var(--card-border); flex-shrink: 0;
    }
    .hero-wordmark { height: 26px; margin-bottom: 8px; }
    .hero-subtitle { font-size: 13px; color: var(--text-secondary); text-align: center; margin-bottom: 16px; }
    .bird-wrap {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, #e8f0ff 0%, #f0e8ff 100%);
      border-radius: 20px; display: flex; align-items: center; justify-content: center;
      box-shadow: var(--shadow-sm), 0 0 0 1px rgba(0,0,0,.05);
    }
    .bird-wrap img { width: 64px; height: 64px; object-fit: contain; }

    /* ── Scroll body ── */
    .scroll-body { flex: 1; overflow-y: auto; min-height: 0; padding: 20px 28px 16px; }
    .scroll-body::-webkit-scrollbar { width: 6px; }
    .scroll-body::-webkit-scrollbar-track { background: transparent; }
    .scroll-body::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .scroll-body::-webkit-scrollbar-thumb:hover { background: #aaa; }

    .section-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: .07em;
      text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 10px;
    }

    /* ── Cards — 4 columns ── */
    .cards-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }

    .card {
      background: #fafafa; border: 1px solid var(--card-border);
      border-radius: var(--radius-md); padding: 14px 14px 12px;
      display: flex; flex-direction: column; align-items: flex-start; gap: 8px;
      cursor: pointer; text-decoration: none; color: var(--text-primary);
      transition: background .12s, box-shadow .12s, transform .12s;
      box-shadow: var(--shadow-sm);
      animation: fadeUp .28s ease both;
    }
    .card:hover { background: #fff; box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .card:active { transform: translateY(0); }
    .card:nth-child(1) { animation-delay: .04s; }
    .card:nth-child(2) { animation-delay: .07s; }
    .card:nth-child(3) { animation-delay: .10s; }
    .card:nth-child(4) { animation-delay: .13s; }
    .card:nth-child(5) { animation-delay: .16s; }
    .card:nth-child(6) { animation-delay: .19s; }
    .card:nth-child(7) { animation-delay: .22s; }
    .card:nth-child(8) { animation-delay: .25s; }

    .card-icon {
      width: 36px; height: 36px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
    }
    .card-icon svg { width: 18px; height: 18px; }
    .card-icon.blue   { background: #dbeafe; color: #2563eb; }
    .card-icon.purple { background: #ede9fe; color: #7c3aed; }
    .card-icon.green  { background: #dcfce7; color: #16a34a; }
    .card-icon.orange { background: #ffedd5; color: #ea580c; }
    .card-icon.teal   { background: #ccfbf1; color: #0d9488; }
    .card-icon.pink   { background: #fce7f3; color: #db2777; }
    .card-icon.amber  { background: #fef3c7; color: #d97706; }
    .card-icon.red    { background: #fee2e2; color: #dc2626; }

    .card-title { font-size: 13px; font-weight: 500; color: var(--text-primary); }
    .card-desc  { font-size: 11.5px; color: var(--text-tertiary); line-height: 1.4; }

    /* ── Actions ── */
    .actions-bar {
      display: flex; align-items: center; justify-content: center;
      gap: 10px; padding: 12px 28px 14px;
      border-top: 1px solid var(--card-border); flex-shrink: 0;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 8px 18px; background: var(--accent); color: #fff;
      font-family: var(--font); font-size: 13px; font-weight: 500;
      border-radius: var(--radius-sm); border: none; cursor: pointer;
      transition: background .12s, transform .1s;
    }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-primary:active { transform: scale(.98); }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 8px 18px; background: transparent; color: var(--text-primary);
      font-family: var(--font); font-size: 13px; font-weight: 500;
      border-radius: var(--radius-sm); border: 1px solid var(--card-border);
      cursor: pointer; box-shadow: var(--shadow-sm);
      transition: background .12s, transform .1s;
    }
    .btn-secondary:hover { background: var(--hover-bg); }
    .btn-secondary:active { transform: scale(.98); }

    /* ── Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 24px; border-top: 1px solid var(--card-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-secondary);
    }
    .discourse-link img { height: 18px; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: var(--hover-bg); color: var(--text-primary); }
    .social-link svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<div class="window">

  <!-- Title Bar — home: traffic lights, no back arrow -->
  <div class="titlebar">
    <div class="traffic-lights">
      <div class="tl tl-close"></div>
      <div class="tl tl-min"></div>
      <div class="tl tl-max"></div>
    </div>
    <span class="titlebar-label">Ubuntu Budgie Welcome</span>
  </div>

  <div class="main">

    <div class="hero">
      <img src="wordmark.svg" alt="Ubuntu Budgie" class="hero-wordmark" />
      <p class="hero-subtitle">Choose an option to discover your new operating system</p>
      <div class="bird-wrap">
        <img src="thebirdonright.png" alt="Ubuntu Budgie mascot" />
      </div>
    </div>

    <div class="scroll-body">
      <p class="section-label">Quick Actions</p>
      <div class="cards-grid">

        <a href="features" class="card">
          <div class="card-icon purple">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
          </div>
          <div class="card-title">Features</div>
          <div class="card-desc">What makes Budgie special</div>
        </a>

        <a href="introduction" class="card">
          <div class="card-icon blue">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>
          </div>
          <div class="card-title">Introduction</div>
          <div class="card-desc">Learn about Budgie</div>
        </a>

        <a href="getting-started" class="card">
          <div class="card-icon green">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.82m5.84-2.56a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.818m2.564-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" /></svg>
          </div>
          <div class="card-title">Getting Started</div>
          <div class="card-desc">Your first steps</div>
        </a>

        <a href="installation" class="card">
          <div class="card-icon orange">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
          </div>
          <div class="card-title">Installation Help</div>
          <div class="card-desc">Setup &amp; troubleshooting</div>
        </a>

        <a href="store" class="card">
          <div class="card-icon teal">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" /></svg>
          </div>
          <div class="card-title">Online Store</div>
          <div class="card-desc">Merchandise &amp; accessories</div>
        </a>

        <a href="community" class="card">
          <div class="card-icon pink">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
          </div>
          <div class="card-title">Community</div>
          <div class="card-desc">Forums, chat &amp; events</div>
        </a>

        <a href="get-involved" class="card">
          <div class="card-icon amber">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>
          </div>
          <div class="card-title">Get Involved</div>
          <div class="card-desc">Contribute to the project</div>
        </a>

        <a href="donate" class="card">
          <div class="card-icon red">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" /></svg>
          </div>
          <div class="card-title">Donate</div>
          <div class="card-desc">Support development</div>
        </a>

      </div>
    </div>

    <div class="actions-bar">
      <button class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:14px;height:14px"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
        Default Settings
      </button>
      <button class="btn-secondary">
        Install Software
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:13px;height:13px"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </button>
    </div>

    <div class="win-footer">
      <a href="#" class="discourse-link">
        <span style="font-size:12px;color:#9b9b9b;">Get support on</span>
        <img src="public/img/logos/discourse-logo-dark.svg" alt="Discourse" />
      </a>
      <div class="social-links">
        <a href="#" class="social-link" title="Blog"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width=".3" d="M19 7h1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V5a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h11.5M7 14h6m-6 3h6m0-10h.5m-.5 3h.5M7 7h3v3H7V7Z"/></svg></a>
