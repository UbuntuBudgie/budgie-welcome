    <script is:inline>
    (function () {
      document.addEventListener('DOMContentLoaded', function () {
        var arrow   = document.getElementById('dropdownArrow');
        var menu    = document.getElementById('dropdownMenu');
        var mainBtn = document.getElementById('installSoftwareMain');

        function toggleMenu() {
          var isOpen = menu.classList.toggle('open');
          arrow.classList.toggle('open', isOpen);
          arrow.setAttribute('aria-expanded', String(isOpen));
        }

        arrow.addEventListener('click', function (e) {
          e.stopPropagation();
          toggleMenu();
        });

        // clicking the main part of the button opens Software Center directly
        mainBtn.addEventListener('click', function () {
          if (typeof cmd === 'function') cmd('software-center');
          menu.classList.remove('open');
          arrow.classList.remove('open');
        });

        // close on outside click
        document.addEventListener('click', function (e) {
          if (!e.target.closest('.dropdown-wrap')) {
            menu.classList.remove('open');
            arrow.classList.remove('open');
          }
        });

        // cmd() stubs for Software Center / Snap / Flatpak
        document.getElementById('menuSoftwareCenter').addEventListener('click', function (e) {
          e.preventDefault();
          if (typeof cmd === 'function') cmd('software-center');
          menu.classList.remove('open'); arrow.classList.remove('open');
        });
        document.getElementById('menuSnapApps').addEventListener('click', function (e) {
          e.preventDefault();
          if (typeof cmd === 'function') cmd('snap-store');
          menu.classList.remove('open'); arrow.classList.remove('open');
        });
        document.getElementById('menuFlatpakApps').addEventListener('click', function (e) {
          e.preventDefault();
          if (typeof cmd === 'function') cmd('flatpak-apps');
          menu.classList.remove('open'); arrow.classList.remove('open');
        });

        document.getElementById('themesBtn').addEventListener('click', function () {
          if (typeof cmd === 'function') cmd('themes-layouts');
        });
      });
    })();
    </script>

