---
// Ubuntu Budgie Welcome — Online Store
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>Ubuntu Budgie Welcome — Online Store</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:            #e8e8e8;
      --win-bg:        #ffffff;
      --bar-bg:        #f5f5f5;
      --bar-border:    #e0e0e0;
      --text-primary:  #1a1a1a;
      --text-secondary:#6b6b6b;
      --text-tertiary: #9b9b9b;
      --accent:        #2563eb;
      --accent-light:  #dbeafe;
      --hover-bg:      #ebebeb;
      --card-border:   #e8e8e8;
      --shadow-sm:     0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
      --shadow-md:     0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
      --shadow-win:    0 20px 60px rgba(0,0,0,.18), 0 8px 24px rgba(0,0,0,.10);
      --radius-sm:     6px;
      --radius-md:     10px;
      --radius-lg:     14px;
      --radius-win:    14px;
      --font:          'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: var(--bg); font-family: var(--font);
      display: flex; align-items: center; justify-content: center;
      padding: 24px;
    }

    /* ── Window ── */
    .window {
      width: 860px; max-width: 100%;
      height: calc(100vh - 48px);
      max-height: 680px; min-height: 480px;
      background: var(--win-bg); border-radius: var(--radius-win);
      box-shadow: var(--shadow-win); overflow: hidden;
      display: flex; flex-direction: column;
      animation: fadeUp .3s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Title Bar ── */
    .titlebar {
      height: 44px; background: var(--bar-bg);
      border-bottom: 1px solid var(--bar-border);
      display: flex; align-items: center;
      padding: 0 16px; gap: 8px;
      flex-shrink: 0; position: relative; user-select: none;
    }
    .back-btn {
      display: flex; align-items: center; gap: 5px;
      background: none; border: none; cursor: pointer;
      color: var(--accent); font-family: var(--font);
      font-size: 13px; font-weight: 500;
      padding: 4px 6px 4px 2px; border-radius: var(--radius-sm);
      transition: background .12s; text-decoration: none;
    }
    .back-btn:hover { background: var(--accent-light); }
    .back-btn svg { width: 16px; height: 16px; }
    .titlebar-label {
      position: absolute; left: 50%; transform: translateX(-50%);
      font-size: 13px; font-weight: 500;
      color: var(--text-secondary); letter-spacing: -.01em; pointer-events: none;
    }

    /* ── Scroll body ── */
    .scroll-body {
      flex: 1; overflow-y: auto; min-height: 0;
    }
    .scroll-body::-webkit-scrollbar { width: 6px; }
    .scroll-body::-webkit-scrollbar-track { background: transparent; }
    .scroll-body::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
    .scroll-body::-webkit-scrollbar-thumb:hover { background: #aaa; }

    /* ── Hero image banner ── */
    .hero-banner {
      width: 100%; overflow: hidden;
      background: linear-gradient(135deg, #eff6ff 0%, #f5f3ff 100%);
      border-bottom: 1px solid var(--card-border);
      position: relative; flex-shrink: 0;
      height: 200px;
      display: flex; align-items: center; justify-content: center;
    }
    .hero-banner img {
      width: 100%; height: 100%; object-fit: cover; object-position: center;
      display: block;
    }
    /* fallback gradient overlay for polish */
    .hero-banner::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(to bottom, transparent 60%, rgba(255,255,255,.35) 100%);
      pointer-events: none;
    }

    /* ── Content area ── */
    .content-area { padding: 26px 32px 28px; }

    /* ── Page heading ── */
    .page-title {
      font-size: 20px; font-weight: 600;
      color: var(--text-primary); letter-spacing: -.02em; margin-bottom: 4px;
    }
    .page-tagline {
      font-size: 13.5px; font-style: italic;
      color: var(--text-secondary); margin-bottom: 14px;
    }
    .page-body {
      font-size: 13px; color: var(--text-secondary); line-height: 1.65;
      margin-bottom: 20px;
    }

    /* ── Merch perk pills ── */
    .perks {
      display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px;
    }
    .perk {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 12px; border-radius: 20px;
      background: #fafafa; border: 1px solid var(--card-border);
      font-size: 12px; font-weight: 500; color: var(--text-secondary);
      animation: fadeUp .28s ease both;
    }
    .perk:nth-child(1) { animation-delay: .04s; }
    .perk:nth-child(2) { animation-delay: .08s; }
    .perk:nth-child(3) { animation-delay: .12s; }
    .perk:nth-child(4) { animation-delay: .16s; }
    .perk span { font-size: 15px; }

    /* ── Info notice ── */
    .info-notice {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 12px 14px; border-radius: var(--radius-sm);
      background: #eff6ff; border: 1px solid #bfdbfe;
      font-size: 12.5px; color: #1e40af; line-height: 1.55;
      margin-bottom: 20px;
    }
    .info-notice svg { width: 15px; height: 15px; flex-shrink: 0; margin-top: 1px; }

    /* ── CTA button ── */
    .cta-row {
      display: flex; align-items: center; justify-content: center;
    }
    .cta-btn {
      display: inline-flex; align-items: center; gap: 9px;
      padding: 11px 28px;
      background: var(--accent); color: #fff;
      font-family: var(--font); font-size: 14px; font-weight: 500;
      border-radius: var(--radius-md); border: none; cursor: pointer;
      text-decoration: none;
      box-shadow: 0 2px 8px rgba(37,99,235,.3);
      transition: background .12s, transform .1s, box-shadow .12s;
    }
    .cta-btn:hover {
      background: #1d4ed8;
      box-shadow: 0 4px 14px rgba(37,99,235,.38);
    }
    .cta-btn:active { transform: scale(.98); }
    .cta-btn img { width: 18px; height: 18px; object-fit: contain; filter: brightness(0) invert(1); }
    .cta-btn svg { width: 15px; height: 15px; }

    /* ── Win Footer ── */
    .win-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 9px 24px; border-top: 1px solid var(--card-border);
      background: var(--bar-bg); flex-shrink: 0;
    }
    .discourse-link {
      display: flex; align-items: center; gap: 7px;
      text-decoration: none; font-size: 12px; color: var(--text-secondary);
    }
    .discourse-link img { height: 18px; }
    .social-links { display: flex; gap: 4px; }
    .social-link {
      width: 28px; height: 28px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-tertiary); text-decoration: none;
      transition: background .12s, color .12s;
      border: none; background: transparent; cursor: pointer;
    }
    .social-link:hover { background: var(--hover-bg); color: var(--text-primary); }
    .social-link svg { width: 14px; height: 14px; }
  </style>
</head>
<body>
<div class="window">

  <!-- Title Bar -->
  <div class="titlebar">
    <a href="index" class="back-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
      </svg>
      Back
    </a>
    <span class="titlebar-label">Online Store</span>
  </div>

  <!-- Scroll Body -->
  <div class="scroll-body">

    <!-- Hero image -->
    <div class="hero-banner">
      <img src="img/shop/ubuntu_budgie_shop_final.png" alt="Ubuntu Budgie merchandise" />
    </div>

    <!-- Content -->
    <div class="content-area">

      <div class="page-title">Ubuntu Budgie Online Store</div>
      <p class="page-tagline">"I supported Ubuntu Budgie, and all I got was this awesome t-shirt!"</p>
      <p class="page-body">
        …and some stickers, a backpack, and more! Would you like to support the project, spread the word, or maybe avoid laundry just one more day? Pick up some merchandise — a portion of every sale goes directly to open-source developers and Ubuntu Budgie itself.
      </p>

      <!-- Merch perks -->
      <div class="perks">
        <div class="perk"><span>👕</span> T-Shirts</div>
        <div class="perk"><span>🎒</span> Backpacks</div>
        <div class="perk"><span>✨</span> Stickers</div>
        <div class="perk"><span>💙</span> Supports open source</div>
      </div>

      <!-- External site notice -->
      <div class="info-notice">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/>
        </svg>
        The button below will take you to an external site for browsing and purchasing.
      </div>

      <!-- CTA -->
      <div class="cta-row">
        <a href="https://ubuntubudgie.org/merch" class="cta-btn">
          <img src="img/distro-icon-inverted.svg" alt="" />
          Visit the Online Store
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

    </div>
  </div><!-- end scroll-body -->

  <!-- Footer -->
  <div class="win-footer">
    <a href="#" class="discourse-link">
      <span style="font-size:12px;color:#9b9b9b;">Get support on</span>
      <img src="public/img/logos/discourse-logo-dark.svg" alt="Discourse" />
    </a>
    <div class="social-links">
      <a href="#" class="social-link" title="Blog"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width=".3" d="M19 7h1v12a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1V5a1 1 0 0 0-1-1H5a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h11.5M7 14h6m-6 3h6m0-10h.5m-.5 3h.5M7 7h3v3H7V7Z"/></svg></a>
      <a href="#" class="social-link" title="Twitter"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/></svg></a>
      <a href="#" class="social-link" title="GitHub"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg></a>
      <a href="#" class="social-link" title="Slack"><svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16"><path d="M3.362 10.11c0 .926-.756 1.681-1.681 1.681S0 11.036 0 10.111C0 9.186.756 8.43 1.68 8.43h1.682v1.68zm.846 0c0-.924.756-1.68 1.681-1.68s1.681.756 1.681 1.68v4.21c0 .924-.756 1.68-1.68 1.68a1.685 1.685 0 0 1-1.682-1.68v-4.21zM5.89 3.362c-.926 0-1.682-.756-1.682-1.681S4.964 0 5.89 0s1.68.756 1.68 1.68v1.682H5.89zm0 .846c.924 0 1.68.756 1.68 1.681S6.814 7.57 5.89 7.57H1.68C.757 7.57 0 6.814 0 5.89c0-.926.756-1.682 1.68-1.682h4.21zm6.749 1.682c0-.926.755-1.682 1.68-1.682.925 0 1.681.756 1.681 1.681s-.756 1.681-1.68 1.681h-1.681V5.89zm-.848 0c0 .924-.755 1.68-1.68 1.68A1.685 1.685 0 0 1 8.43 5.89V1.68C8.43.757 9.186 0 10.11 0c.926 0 1.681.756 1.681 1.68v4.21zm-1.681 6.748c.926 0 1.682.756 1.682 1.681S11.036 16 10.11 16s-1.681-.756-1.681-1.68v-1.682h1.68zm0-.847c-.924 0-1.68-.755-1.68-1.68 0-.925.756-1.681 1.68-1.681h4.21c.924 0 1.68.756 1.68 1.68 0 .926-.756 1.681-1.68 1.681h-4.21z"/></svg></a>
    </div>
  </div>

</div>
</body>
</html>